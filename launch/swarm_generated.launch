    <arg name="x" value="-0.93"/>
    <arg name="y" value="-2.85"/>
    <arg name="drone_id" value="8"/>
    <arg name="swarm_size" value="10"/>
    <arg name="swarm_formation" value="helix"/>
  </include>

  <include file="$(find flie_swarm_core)/launch/spawn_drone.launch">
